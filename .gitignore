# ==========================================
# .gitignore - Projet GROS MUSCLES
# ==========================================

# --- 1. SECRETS & CLÉS D'API (CRUCIAL 🚨) ---
.env
.env.local
.env.*.local
*.pem
secrets.json

# --- 2. BASE DE DONNÉES LOCALE ---
# On ignore les bases SQLite pour que chacun ait sa propre base en local
# et pour ne pas créer de conflits de fusion (merge conflicts)
*.db
*.sqlite
*.sqlite3
gros_muscles.db

# --- 3. PYTHON / FASTAPI (BACKEND) ---
__pycache__/
*.py[cod]
*$py.class
# Environnements virtuels (ne jamais push l'environnement complet !)
venv/
env/
.venv/
env.bak/
venv.bak/
# Logs
*.log

# --- 4. REACT / REACT NATIVE / EXPO (FRONTEND) ---
# Dossier ultra-lourd à ne jamais mettre sur Git !
node_modules/
# Fichiers générés par Expo et le build
.expo/
dist/
build/
web-build/
# Fichiers de log d'erreurs npm/yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.eslintcache

# --- 5. SYSTÈMES D'EXPLOITATION (OS) ---
# Mac
.DS_Store
.AppleDouble
.LSOverride
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# --- 6. ÉDITEURS DE CODE (IDE) ---
.vscode/
.idea/
*.swp
*.swo

# Environnements virtuels (ne jamais push l'environnement complet !)
venv/
env/
.venv/
env.bak/
venv.bak/