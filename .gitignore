# ============================================================
# Fichier .gitignore pour le projet GrosMuscles
# ============================================================

# --- Fichiers et dossiers généraux ---
# Fichiers de configuration des IDEs
.idea/
.vscode/
*.swp
*.swo

# Fichiers système (macOS, Windows)
.DS_Store
Thumbs.db

# --- Backend (Python / FastAPI) ---
# Dossier de l'environnement virtuel
application-grosmuscles/FastAPI/venv/
application-grosmuscles/FastAPI/.venv/

# Cache Python
application-grosmuscles/FastAPI/__pycache__/
*.pyc

# Fichiers de build et de distribution
application-grosmuscles/FastAPI/build/
application-grosmuscles/FastAPI/dist/
application-grosmuscles/FastAPI/*.egg-info/

# --- Frontend (React Native / Expo) ---
# Dépendances
application-grosmuscles/frontend/node_modules/

# Dossiers de build et de cache Expo
application-grosmuscles/frontend/.expo/
application-grosmuscles/frontend/web-build/
application-grosmuscles/frontend/dist/

# Fichiers de log
application-grosmuscles/frontend/npm-debug.log*
application-grosmuscles/frontend/yarn-debug.log*
application-grosmuscles/frontend/yarn-error.log*


# --- Base de données ---
# La base de données SQLite est volontairement NON ignorée pour conserver les données du MVP.
# Si vous souhaitez l'ignorer, décommentez la ligne suivante :
# application-grosmuscles/FastAPI/grosmuscles.db
